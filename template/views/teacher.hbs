<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Potal</title>
</head>

<body>
    <!DOCTYPE html>
    <html>

    <head>
        <title>Registration Form</title>
        <style>
            body {
                font-family: Arial, sans-serif;
                background-color: #a6f393;
                margin: 0;
                padding: 0;
            }

            .container {
                width: 50%;
                margin: 50px auto;
                background: #fff;
                padding: 20px;
                border-radius: 10px;
                box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.1);
            }

            form {
                margin-top: 20px;
            }

            label {
                display: block;
                margin-bottom: 5px;
            }

            input[type="text"],
            input[type="number"],
            input[type="email"],
            input[type="password"] {
                width: 100%;
                padding: 10px;
                margin-bottom: 15px;
                border: 1px solid #ccc;
                border-radius: 5px;
                box-sizing: border-box;
                font-size: 16px;
            }

            input[type="submit"] {
                background-color: #4caf50;
                color: white;
                padding: 12px 20px;
                border: none;
                border-radius: 5px;
                cursor: pointer;
                font-size: 16px;
            }

            input[type="submit"]:hover {
                background-color: #45a049;
            }

            .green {
                color: green;
            }

            .red {
                color: red;
            }
        </style>
    </head>

    <body>
        {{>navbar}}
        <div class="container">
            <h2>Store Marks</h2>
            <form action="./teacher" method="post">

                <label for="roll_number">roll_number:</label>
                <input type="number" name="roll_number" id="roll_number" maxlength="5" required
                    placeholder="Enter The student Roll number">

                <label for="addhar_number">addhar_number:</label>
                <input type="number" name="addhar_number" id="addhar_number" maxlength="11" required
                    placeholder="Enter The student addhar_number">

                <label for="fname">Name:</label>
                <input type="text" name="fname" id="fname" required placeholder="Enter Student Name">


                <label for="Hindi">Hindi:</label>
                <input type="number" name="hindi" id="hindi" required placeholder="enter hindi marks">

                <label for="english">English:</label>
                <input type="number" name="english" id="english" required placeholder="Enter english marks">

                <label for="Maths">Maths:</label>
                <input type="Number" name="Maths" id="Maths" required placeholder="Enter Maths marks">

                <label for="Result">Result:</label>
                <input type="text" name="Result" id="Result" required placeholder="Enter Result">

                <label for="TOTAL">TOTAL:</label>
                <input type="Number" name="TOTAL" id="TOTAL" required placeholder="Enter TOTOL marks">

                <h2 class="green">{{success}}</h2>
                <h2 class="red">{{error}}</h2>

                <input type="submit" value="Submit">
            </form>
        </div>
    </body>

    </html>

</body>

</html>