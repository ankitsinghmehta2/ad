<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>coding academy Home page</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <style>
    body
{
  background-color: rgb(176, 237, 155);
}    .main {
      display: flex;
      justify-content:  space-around;
      align-items: center;
    }
  

    .btn {
      box-shadow: 15px 15px 35px black;
      display: inline-block;
      padding: 100px 100px;
      margin: 10px 90px;
      background-color: #04AA6D;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 2rem;
      text-decoration: none;
      cursor: pointer;
      margin-bottom: 100px;
    }

    .btn:hover {
      background-color: rgb(33, 105, 84);
      color: white;
    }
    h1,h2{
     font-family: sans-serif;
      font-size: 2rem;
      text-align: center;
    }
  </style>
</head>

<body>
  {{>navbar}}
  <div id="carouselExample" class="carousel slide">
  <div class="carousel-inner" style="margin-bottom: 50px;">
    <div class="carousel-item active">
      <img src="c1.jpg" class="d-block w-100" alt="..." height="500px" >
    </div>
    <div class="carousel-item">
      <img src="c4.jpg" class="d-block w-100" alt="..." height="500px">
    </div>
    <div class="carousel-item">
      <img src="c3.jpeg" class="d-block w-100" alt="..." height="500px">
    </div>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div> 

  <h1>CODING ACADEMY ,PITHORAGARH UTTARAKHAND </h1>
  <H2>PITHORAGARH BRANCH</H2>
  <div class="main">
    <a href=student class="btn">Student Login</a>
    <a href=teacher class="btn">Teacher Login</a>
    <a href=addmision class="btn">Admission</a>

  </div>


  
  {{>footer}}


</body>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

