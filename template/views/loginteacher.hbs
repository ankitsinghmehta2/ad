<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
       body
{
  background-color: rgb(176, 237, 155);
} 
        form {
          border: none;
          border-radius: 20px;
          box-shadow: 3px 3px 10px black;
            font-size: 30px;
            width: 50%;
            padding: 30px;
            height: 60%;
            margin-top: 120px;
            margin-left: 20%;
            
        }
        label {
            font-weight: bold;
        }
        .password > label {
            padding-left: 0; /* Remove unnecessary padding */
        }
        input{
          border: 11px solid blaCK;
        }
        .red{
          color: red;
          font-weight: 800;
          font-size: 18px;
        }
        .green{
          color: green;
          font-weight: 800;
          font-size: 18px;

        }
    </style>
</head>
<body>
    {{>navbar}}
  
    <form action="/loginteacher" method="post">
        <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" placeholder="Enter The Username" class="form-control" id="username" name="username" aria-describedby="emailHelp">
           
        <div class="mb-3">
            <label for="password" class="form-label">password</label>
            <input type="password" placeholder="Enter the password" class="form-control" id="password" name="password">
        </div>
        
         <div id="emailHelp" class="form-text">We'll never share your Username and password with anyone else.</div>
        </div>
          <h2 class="green">{{success}}</h2>
          <h2 class="red">{{wrong}}</h2>
          <h2 class="red">{{notfound}}</h2>

        <button 
        type="submit" class="btn btn-primary">Submit</button>
    </form>
</body>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</html>
